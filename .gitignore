plan.bat
plan-prod.bat
destroy.bat
terraform/.terraform/*

# Local .terraform directories
# (.terraform.lock.hcl is intentionally NOT ignored — commit it per HashiCorp guidance)
**/.terraform/*

# Local persistent agent plans
/plans/

# Ignore variables files
*.auto.tfvars
*.tfvars.local

.terraformrc

# Ignore override files
*.tfoverride

# Ignore environment-specific files
.envrc
.env
.env.*

# Ignore CLI configuration files
terraform.rc
/terraform/.terraform/**

# Terraform state and plans — never commit
*.tfstate
*.tfstate.*
**/tfplan
**/tfplan.*
**/plan.json

# Credential material — never commit
**/*credentials*.json
**/*service-account*.json
**/gcp-credentials.json
**/*sa-key*.json
**/*-key.json
i-binder-*.json
*.pem
*.p12
*.pfx
kubeconfig
kubeconfig.*
