#!/usr/bin/env bash
# Reject commits containing secret-like content. Requires gitleaks on PATH.
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "WARNING: gitleaks not installed - skipping secret scan (install: https://github.com/gitleaks/gitleaks)" >&2
  exit 0
fi
exec gitleaks protect --staged --verbose
